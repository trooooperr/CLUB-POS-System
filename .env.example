# =============================================================
#  HumTum POS — Environment Variables Reference
#  Copy this file to .env and fill in your values.
# =============================================================

# ── DATABASE (REQUIRED) ──────────────────────────────────────
# Your MongoDB Atlas connection string (SRV format recommended)
# Get this from: Atlas Dashboard → Cluster → Connect → Drivers
CLOUD_MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Use local MongoDB instead of cloud (dev only, set to true)
USE_LOCAL_DB=false
LOCAL_MONGO_URI=mongodb://localhost:27017/humtum-bar-pos

# Use in-memory MongoDB (for tests only)
USE_MEMORY_DB=false

# ── SECURITY (REQUIRED) ──────────────────────────────────────
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_WITH_CRYPTO_RANDOMBYTES

# Secret for cron-job routes (used by scheduled report calls)
CRON_SECRET=CHANGE_ME_STRONG_CRON_SECRET

# ── SERVER ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS (OPTIONAL) ─────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave empty to allow all origins in dev, or lock down in prod.
# Example: https://humtum.yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5176

# ── EMAIL / REPORTS (REQUIRED for daily email report) ────────
# Gmail sender account (used to send daily reports)
GMAIL_SENDER=your-gmail@gmail.com
# Gmail App Password (NOT your regular password):
#   Google Account → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Admin email address that receives the daily report
ADMIN_EMAIL=owner@example.com

# Alternative SMTP (optional — leave blank to use Gmail above)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-user@example.com

# ── REDIS / CACHE (REQUIRED for caching) ─────────────────────
# Upstash Redis REST endpoint and token
# Get from: https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Prefix for all Redis keys (useful to avoid collisions between envs)
REDIS_PREFIX=humtum_

# ── SCHEDULED REPORTS ────────────────────────────────────────
# Cron expression for daily report (default: 5:00 AM IST)
# Uses Asia/Kolkata timezone
REPORT_CRON=0 5 * * *

# ── RESTAURANT ───────────────────────────────────────────────
RESTAURANT_NAME=HumTum Bar & Restaurant

# ── FRONTEND (build-time, set in frontend/.env) ──────────────
# URL of the backend API used by the frontend during dev
# Leave empty in production (frontend auto-detects from window.location.origin)
VITE_API_URL=http://localhost:3001
